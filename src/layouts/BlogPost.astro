---
// import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
// import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import BlogHeader from "../components/BlogHeader.astro";

type Props = CollectionEntry<"blog">;

const { ...post } = Astro.props;
---

<html lang="en" data-theme="dark">
	<head>
		<BaseHead title={post.data.title} description={post.data.description} />
		<style>
			main {
				width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: min(100%, 720px);
				max-width: 100%;
				margin: auto;
				padding: 1rem;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}

			.blog-prose {
				color: var(--theme-text);
			}

			.blog-prose :global(h1),
			.blog-prose :global(h2),
			.blog-prose :global(h3),
			.blog-prose :global(h4),
			.blog-prose :global(h5),
			.blog-prose :global(h6) {
				color: var(--theme-primary);
				line-height: 1.2;
			}

			.blog-prose :global(h1) {
				font-size: clamp(1.75rem, 5vw, 2.5rem);
				margin: 0 0 1rem;
			}

			.blog-prose :global(h2) {
				font-size: clamp(1.35rem, 4vw, 2rem);
				margin: 2rem 0 0.75rem;
			}

			.blog-prose :global(h3) {
				font-size: clamp(1.15rem, 3vw, 1.5rem);
				margin: 1.5rem 0 0.75rem;
			}

			.blog-prose :global(p),
			.blog-prose :global(li) {
				line-height: 1.8;
			}

			.blog-prose :global(p),
			.blog-prose :global(ul),
			.blog-prose :global(ol),
			.blog-prose :global(pre),
			.blog-prose :global(blockquote) {
				margin: 0 0 1rem;
			}

			.blog-prose :global(ul),
			.blog-prose :global(ol) {
				padding-left: 1.25rem;
			}

			.blog-prose :global(a) {
				color: var(--theme-primary);
				text-decoration: underline;
				text-underline-offset: 0.2em;
			}

			.blog-prose :global(code) {
				background-color: var(--theme-welcomeBoxBg);
				color: var(--theme-accent);
				border-radius: 0.375rem;
				padding: 0.125rem 0.375rem;
				word-break: break-word;
			}

			.blog-prose :global(pre) {
				overflow-x: auto;
				padding: 1rem;
				border-radius: 0.75rem;
				background-color: var(--theme-welcomeBoxBg);
				border: 1px solid var(--theme-border);
			}

			.blog-prose :global(pre code) {
				background: transparent;
				padding: 0;
			}

			.blog-prose :global(img) {
				width: 100%;
				height: auto;
				border-radius: 0.75rem;
			}

			.blog-prose :global(blockquote) {
				margin-left: 0;
				padding-left: 1rem;
				border-left: 3px solid var(--theme-border);
				color: var(--theme-outputText);
			}

			@media (max-width: 640px) {
				.prose {
					padding: 0;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<div
			class="min-h-screen font-mono"
			style={{
				backgroundColor: "var(--theme-background)",
				color: "var(--theme-text)",
			}}
		>
			<div class="safe-px max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-6 sm:py-8 pb-8 md:pb-16">
				<div class="lg:flex lg:gap-8">
					{/* Main content */}
					<div class="lg:flex-1 lg:max-w-4xl">
						<BlogHeader {...Astro.props} />
						<div
							class="rounded-lg shadow-sm border p-4 sm:p-6 md:p-8 mb-8"
							style={{
								borderColor: "var(--theme-border)",
							}}
						>
							<div class="blog-prose prose prose-lg max-w-none">
								<slot />
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
		<Footer />
	</body>
</html>
