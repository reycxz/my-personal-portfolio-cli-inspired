---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { resumeData } from "../data/resume";
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<BaseHead title={`Resume | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div
			class="min-h-screen flex flex-col"
			style={{
				backgroundColor: "var(--theme-background)",
				color: "var(--theme-text)",
			}}
		>
			<Header />
			<main class="flex-1 max-w-5xl mx-auto w-full px-3 sm:px-6 py-6 sm:py-10 font-mono">
				<div class="border rounded-lg overflow-hidden shadow-xl" style={{ borderColor: "var(--theme-border)" }}>
					<div class="px-4 sm:px-6 py-4 border-b flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3" style={{ borderColor: "var(--theme-border)", backgroundColor: "var(--theme-welcomeBoxBg)" }}>
						<div>
							<p class="text-xs uppercase tracking-[0.2em]" style={{ color: "var(--theme-muted)" }}>Resume / CV</p>
							<h1 class="text-2xl sm:text-3xl font-bold" style={{ color: "var(--theme-primary)" }}>{resumeData.basics.name}</h1>
							<p class="text-sm sm:text-base mt-1" style={{ color: "var(--theme-outputText)" }}>{resumeData.basics.title}</p>
						</div>
						<div class="flex flex-wrap gap-2">
							<a href="/" class="px-3 py-2 rounded border text-sm hover:opacity-80" style={{ borderColor: "var(--theme-border)", color: "var(--theme-outputText)" }}>Back to terminal</a>
							<a href="/CABANOG_REYLORENZ_RESUME-updated.pdf" target="_blank" rel="noopener noreferrer" class="px-3 py-2 rounded border text-sm hover:opacity-80" style={{ borderColor: "var(--theme-border)", color: "var(--theme-outputText)" }}>Download PDF</a>
							<button id="print-resume" class="px-3 py-2 rounded text-sm font-semibold" style={{ backgroundColor: "var(--theme-accent)", color: "var(--theme-background)" }}>Print / Save PDF</button>
						</div>
					</div>

					<div class="p-4 sm:p-6 space-y-8" style={{ backgroundColor: "var(--theme-background)" }}>
						<section class="grid grid-cols-1 lg:grid-cols-[2fr_1fr] gap-6">
							<div>
								<h2 class="text-lg font-bold mb-3" style={{ color: "var(--theme-info)" }}>Summary</h2>
								<div class="space-y-2" style={{ color: "var(--theme-outputText)" }}>
									{resumeData.summary.map((line) => <p class="leading-7">{line}</p>)}
								</div>
								<div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
									<div>
										<p style={{ color: "var(--theme-muted)" }}>Location</p>
										<p>{resumeData.basics.location}</p>
									</div>
									<div>
										<p style={{ color: "var(--theme-muted)" }}>Phone / Email</p>
										<p>{resumeData.basics.phone}</p>
										<p>{resumeData.basics.email}</p>
									</div>
									<div>
										<p style={{ color: "var(--theme-muted)" }}>GitHub</p>
										<a href={resumeData.basics.github} target="_blank" rel="noopener noreferrer" class="hover:underline" style={{ color: "var(--theme-primary)" }}>{resumeData.basics.github}</a>
									</div>
									<div>
										<p style={{ color: "var(--theme-muted)" }}>LinkedIn</p>
										<a href={resumeData.basics.linkedin} target="_blank" rel="noopener noreferrer" class="hover:underline" style={{ color: "var(--theme-primary)" }}>{resumeData.basics.linkedin}</a>
									</div>
								</div>
							</div>
							<div class="rounded-lg border p-4" style={{ borderColor: "var(--theme-border)", backgroundColor: "var(--theme-welcomeBoxBg)" }}>
								<h2 class="text-lg font-bold mb-3" style={{ color: "var(--theme-warning)" }}>Highlights</h2>
								<ul class="space-y-2 text-sm" style={{ color: "var(--theme-outputText)" }}>
									<li>Working student</li>
									<li>Cybersecurity-focused Computer Engineering student</li>
									<li>Cisco certifications in networking and security</li>
									<li>Experience in dispatch, ticketing, chat, and voice support</li>
								</ul>
							</div>
						</section>

						<section>
							<h2 class="text-lg font-bold mb-3" style={{ color: "var(--theme-info)" }}>Work Experience</h2>
							<div class="space-y-4">
								{resumeData.workExperience.map((job) => (
									<div class="rounded border px-4 py-4" style={{ borderColor: "var(--theme-border)", backgroundColor: "var(--theme-welcomeBoxBg)" }}>
										<div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2">
											<div>
												<p class="font-semibold" style={{ color: "var(--theme-primary)" }}>{job.title}</p>
												<p class="text-sm" style={{ color: "var(--theme-outputText)" }}>{job.company} • {job.location}</p>
											</div>
											<p class="text-sm" style={{ color: "var(--theme-muted)" }}>{job.period}</p>
										</div>
										<ul class="mt-3 space-y-2 text-sm" style={{ color: "var(--theme-outputText)" }}>
											{job.bullets.map((bullet) => <li>• {bullet}</li>)}
										</ul>
									</div>
								))}
							</div>
						</section>

						<section>
							<h2 class="text-lg font-bold mb-3" style={{ color: "var(--theme-info)" }}>Education</h2>
							<div class="space-y-4">
								{resumeData.education.map((entry) => (
									<div class="rounded border px-4 py-4" style={{ borderColor: "var(--theme-border)", backgroundColor: "var(--theme-welcomeBoxBg)" }}>
										<div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2">
											<div>
												<p class="font-semibold" style={{ color: "var(--theme-primary)" }}>{entry.degree}</p>
												<p class="text-sm" style={{ color: "var(--theme-outputText)" }}>{entry.school}</p>
											</div>
											<p class="text-sm" style={{ color: "var(--theme-muted)" }}>{entry.period}</p>
										</div>
										{entry.bullets.length > 0 && (
											<ul class="mt-3 space-y-2 text-sm" style={{ color: "var(--theme-outputText)" }}>
												{entry.bullets.map((bullet) => <li>• {bullet}</li>)}
											</ul>
										)}
									</div>
								))}
							</div>
						</section>

						<section class="grid grid-cols-1 xl:grid-cols-2 gap-6">
							<div>
								<h2 class="text-lg font-bold mb-3" style={{ color: "var(--theme-info)" }}>Certifications</h2>
								<div class="space-y-3">
									{resumeData.certifications.map((cert) => (
										<div class="rounded border px-4 py-3 text-sm" style={{ borderColor: "var(--theme-border)", backgroundColor: "var(--theme-welcomeBoxBg)", color: "var(--theme-outputText)" }}>{cert}</div>
									))}
								</div>
							</div>

							<div>
								<h2 class="text-lg font-bold mb-3" style={{ color: "var(--theme-info)" }}>Technical Skills</h2>
								<div class="space-y-3">
									{resumeData.skillGroups.map((group) => (
										<div class="rounded border px-4 py-3" style={{ borderColor: "var(--theme-border)", backgroundColor: "var(--theme-welcomeBoxBg)" }}>
											<p class="font-semibold" style={{ color: "var(--theme-primary)" }}>{group.name}</p>
											<p class="text-sm mt-2" style={{ color: "var(--theme-outputText)" }}>{group.items.join(", ")}</p>
										</div>
									))}
								</div>
							</div>
							</div>
						</section>
					</div>
				</div>
			</main>
			<Footer />
		</div>
	</body>
</html>

<script>
	const printButton = document.getElementById("print-resume");
	printButton?.addEventListener("click", () => window.print());
</script>