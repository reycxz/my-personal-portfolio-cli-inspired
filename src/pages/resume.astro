---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import profileConfig from "../../profile.config";
import githubData from "../data/github-projects.json" assert { type: "json" };

const { profile, socialLinks, skills, achievements, stats } = profileConfig;
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<BaseHead title={`Resume | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div
			class="min-h-screen flex flex-col"
			style={{
				backgroundColor: "var(--theme-background)",
				color: "var(--theme-text)",
			}}
		>
			<Header />
			<main class="flex-1 max-w-5xl mx-auto w-full px-3 sm:px-6 py-6 sm:py-10 font-mono">
				<div class="border rounded-lg overflow-hidden shadow-xl" style={{ borderColor: "var(--theme-border)" }}>
					<div class="px-4 sm:px-6 py-4 border-b flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3" style={{ borderColor: "var(--theme-border)", backgroundColor: "var(--theme-welcomeBoxBg)" }}>
						<div>
							<p class="text-xs uppercase tracking-[0.2em]" style={{ color: "var(--theme-muted)" }}>Resume / CV</p>
							<h1 class="text-2xl sm:text-3xl font-bold" style={{ color: "var(--theme-primary)" }}>{profile.name}</h1>
							<p class="text-sm sm:text-base mt-1" style={{ color: "var(--theme-outputText)" }}>{profile.title}</p>
						</div>
						<div class="flex flex-wrap gap-2">
							<a href="/" class="px-3 py-2 rounded border text-sm hover:opacity-80" style={{ borderColor: "var(--theme-border)", color: "var(--theme-outputText)" }}>Back to terminal</a>
							<button id="print-resume" class="px-3 py-2 rounded text-sm font-semibold" style={{ backgroundColor: "var(--theme-accent)", color: "var(--theme-background)" }}>Print / Save PDF</button>
						</div>
					</div>

					<div class="p-4 sm:p-6 space-y-8" style={{ backgroundColor: "var(--theme-background)" }}>
						<section class="grid grid-cols-1 lg:grid-cols-[2fr_1fr] gap-6">
							<div>
								<h2 class="text-lg font-bold mb-3" style={{ color: "var(--theme-info)" }}>Profile</h2>
								<p class="leading-7" style={{ color: "var(--theme-outputText)" }}>{profile.bio}</p>
								<div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
									<div>
										<p style={{ color: "var(--theme-muted)" }}>Location</p>
										<p>{profile.location}</p>
									</div>
									<div>
										<p style={{ color: "var(--theme-muted)" }}>Email</p>
										<p>{profile.email}</p>
									</div>
									<div>
										<p style={{ color: "var(--theme-muted)" }}>GitHub</p>
										<a href={socialLinks.github} target="_blank" rel="noopener noreferrer" class="hover:underline" style={{ color: "var(--theme-primary)" }}>{socialLinks.github}</a>
									</div>
									<div>
										<p style={{ color: "var(--theme-muted)" }}>LinkedIn</p>
										<a href={socialLinks.website} target="_blank" rel="noopener noreferrer" class="hover:underline" style={{ color: "var(--theme-primary)" }}>{socialLinks.website}</a>
									</div>
								</div>
							</div>
							<div class="rounded-lg border p-4" style={{ borderColor: "var(--theme-border)", backgroundColor: "var(--theme-welcomeBoxBg)" }}>
								<h2 class="text-lg font-bold mb-3" style={{ color: "var(--theme-warning)" }}>Snapshot</h2>
								<ul class="space-y-2 text-sm" style={{ color: "var(--theme-outputText)" }}>
									<li>Projects: {stats.projects}</li>
									<li>GitHub Repos: {githubData.stats.totalRepos}</li>
									<li>Total Stars: {githubData.stats.totalStars}</li>
									<li>Contribution Streak: {stats.streak}</li>
								</ul>
							</div>
						</section>

						<section>
							<h2 class="text-lg font-bold mb-3" style={{ color: "var(--theme-info)" }}>Current Focus</h2>
							<ul class="grid grid-cols-1 md:grid-cols-2 gap-3">
								{profile.currentFocus.map((item) => (
									<li class="rounded border px-4 py-3" style={{ borderColor: "var(--theme-border)", backgroundColor: "var(--theme-welcomeBoxBg)", color: "var(--theme-outputText)" }}>{item}</li>
								))}
							</ul>
						</section>

						<section>
							<h2 class="text-lg font-bold mb-3" style={{ color: "var(--theme-info)" }}>Skills</h2>
							<div class="flex flex-wrap gap-2">
								{skills.map((skill) => (
									<span class="px-3 py-2 rounded border text-sm" style={{ borderColor: "var(--theme-border)", backgroundColor: "var(--theme-welcomeBoxBg)", color: "var(--theme-outputText)" }}>{skill}</span>
								))}
							</div>
						</section>

						<section>
							<h2 class="text-lg font-bold mb-3" style={{ color: "var(--theme-info)" }}>Highlights</h2>
							<div class="space-y-3">
								{achievements.map((achievement) => (
									<div class="rounded border px-4 py-3" style={{ borderColor: "var(--theme-border)", backgroundColor: "var(--theme-welcomeBoxBg)" }}>
										<p class="font-semibold" style={{ color: "var(--theme-primary)" }}>{achievement.title}</p>
										<p class="text-sm mt-1" style={{ color: "var(--theme-outputText)" }}>{achievement.description}</p>
									</div>
								))}
							</div>
						</section>
					</div>
				</div>
			</main>
			<Footer />
		</div>
	</body>
</html>

<script>
	const printButton = document.getElementById("print-resume");
	printButton?.addEventListener("click", () => window.print());
</script>