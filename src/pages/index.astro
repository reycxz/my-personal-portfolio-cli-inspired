---
import BaseHead from "../components/BaseHead.astro";
import CommandOutput from "../components/CommandOutput.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE, terminalConfig } from "../consts";
import { resumePdfPath, terminalResumeLines } from "../data/resume";

const desktopWelcomeMark = [
	"██╗ █████╗ ███╗   ███╗██████╗ ███████╗██╗   ██╗",
	"██║██╔══██╗████╗ ████║██╔══██╗██╔════╝╚██╗ ██╔╝",
	"██║███████║██╔████╔██║██████╔╝█████╗   ╚████╔╝ ",
	"██║██╔══██║██║╚██╔╝██║██╔══██╗██╔══╝    ╚██╔╝  ",
	"██║██║  ██║██║ ╚═╝ ██║██║  ██║███████╗   ██║   ",
	"╚═╝╚═╝  ╚═╝╚═╝     ╚═╝╚═╝  ╚═╝╚══════╝   ╚═╝   ",
];

const desktopWelcomeMeta = "iamrey.dev // developer terminal";
const mobileWelcomeMark = ["iamrey.dev", "developer terminal"];
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div
			class="min-h-screen flex flex-col"
			style={{
				backgroundColor: "var(--theme-background)",
				color: "var(--theme-text)",
			}}
		>
			<Header />

			<main class="flex-1">
				<div
					id="terminal-container"
					class="terminal-scroll pt-0 font-mono space-y-2 min-h-[calc(100dvh-8rem)] overflow-visible max-w-screen-xl mx-auto w-full p-3 sm:p-4 sm:h-[calc(100dvh-160px)] sm:overflow-y-auto"
					style={{
						backgroundColor: "var(--theme-background)",
						color: "var(--theme-text)",
						fontFamily: "var(--theme-fontFamily)",
					}}
				>
					<div id="command-output" class="flex-col w-full mb-2" style="display: none;"></div>
					
					<!-- Terminal Prompt -->
					<div
						class="input-shell flex flex-wrap items-center gap-2 pt-2 px-2 sm:px-0 text-sm sm:text-base"
						style={{ color: "var(--theme-commandText)" }}
					>
						<span
							class="hidden sm:inline"
							style={{ color: "var(--theme-promptUser)" }}
							>user@{terminalConfig.hostname}</span
						>
						<span
							class="hidden sm:inline"
							style={{ color: "var(--theme-text)" }}>:</span
						>
						<span
							class="hidden sm:inline"
							style={{ color: "var(--theme-promptPath)" }}>~</span
						>
						<span style={{ color: "var(--theme-promptSymbol)" }}
							>$
						</span>
						<input
							id="terminal-input"
							type="text"
							class="bg-transparent border-none outline-none flex-1 min-w-0 font-mono text-base sm:text-base py-2"
							style={{ color: "var(--theme-text)" }}
						/>
					</div>
					<!-- Welcome Page -->
					<div
						id="welcome-box"
						class="mb-4 sm:mb-6"
						style={{ color: "var(--theme-primary)" }}
					>
						<div
							class="rounded-lg p-4 sm:p-6 shadow-lg overflow-hidden"
							style={{
								border: `2px solid var(--theme-welcomeBoxBorder)`,
								backgroundColor: "var(--theme-welcomeBoxBg)",
							}}
						>
							{
								desktopWelcomeMark.length > 0 && (
									<>
										<div class="hidden md:flex flex-col items-center mb-5 gap-2 overflow-x-auto">
											<pre
												class="welcome-ascii w-fit text-[0.86rem] lg:text-[1.02rem] xl:text-[1.08rem] leading-[0.96] whitespace-pre mx-auto"
												style={{ color: "var(--theme-primary)" }}
											>{desktopWelcomeMark.join("\n")}</pre>
											<p
												class="text-xs uppercase tracking-[0.32em]"
												style={{ color: "var(--theme-info)" }}
											>
												{desktopWelcomeMeta}
											</p>
										</div>
										<div class="md:hidden flex justify-center mb-4">
											<div
												class="rounded-2xl px-4 py-3 text-center border min-w-[15rem]"
												style={{
													borderColor: "var(--theme-welcomeBoxBorder)",
													backgroundColor: "color-mix(in srgb, var(--theme-background) 70%, transparent)",
												}}
											>
												<pre
													class="welcome-ascii-mobile text-[1rem] font-bold leading-tight whitespace-pre-wrap"
													style={{ color: "var(--theme-primary)" }}
												>{mobileWelcomeMark.join("\n")}</pre>
											</div>
										</div>
									</>
								)
							}
							<div class="text-center mb-4 sm:mb-5">
								<div class="hidden sm:block text-2xl sm:text-3xl mb-2">
									╭────────────────────────────╮
								</div>
								<div class="sm:hidden inline-flex rounded-full px-3 py-1 text-xs border" style={{ borderColor: "var(--theme-welcomeBoxBorder)", color: "var(--theme-primary)" }}>
									terminal session active
								</div>
								<div
									id="welcome-title"
									class="text-base sm:text-xl font-bold mb-1 px-2 sm:px-0"
									style={{ color: "var(--theme-primary)" }}
								>
									> Welcome to {terminalConfig.hostname} Terminal
								</div>
								<div class="hidden sm:block text-2xl sm:text-3xl mb-3">
									╰────────────────────────────╯
								</div>
							</div>

							<div
								class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 mb-4"
							>
								<div
									class="rounded p-3"
									style={{
										backgroundColor:
											"var(--theme-background)",
										border: `1px solid var(--theme-border)`,
									}}
								>
									<h3
										class="font-semibold mb-2 flex items-center"
										style={{
											color: "var(--theme-warning)",
										}}
									>
										> Quick Start
									</h3>
									<ul
										class="text-sm space-y-1"
										style={{ color: "var(--theme-muted)" }}
									>
										<li>
											• Type <span
												class="font-mono"
												style={{
													color: "var(--theme-primary)",
												}}>help</span
											> for commands
										</li>
										<li>
											• Try <span
												class="font-mono"
												style={{
													color: "var(--theme-info)",
												}}>neofetch</span
											> for system info
										</li>
										<li>
											• Use <span
												class="font-mono"
												style={{
													color: "var(--theme-secondary)",
												}}>skills</span
											> to see my expertise
										</li>
										<li>
											• Run <span
												class="font-mono"
												style={{
													color: "var(--theme-accent)",
												}}>joke</span
											> for some fun!
										</li>
									</ul>
								</div>

								<div
									class="rounded p-3"
									style={{
										backgroundColor:
											"var(--theme-background)",
										border: `1px solid var(--theme-border)`,
									}}
								>
									<h3
										class="font-semibold mb-2 flex items-center"
										style={{ color: "var(--theme-info)" }}
									>
										> Pro Tips
									</h3>
									<ul
										class="text-sm space-y-1"
										style={{ color: "var(--theme-muted)" }}
									>
										<li>• ↑/↓ arrows: Command history</li>
										<li>• Tab: Auto-complete commands</li>
										<li>• Ctrl+L: Clear terminal</li>
										<li>
											• Try aliases: <span
												class="font-mono"
												style={{
													color: "var(--theme-primary)",
												}}>ll</span
											>, <span
												class="font-mono"
												style={{
													color: "var(--theme-primary)",
												}}>..</span
											>, <span
												class="font-mono"
												style={{
													color: "var(--theme-primary)",
												}}>h</span
											>
										</li>
									</ul>
								</div>
							</div>

							<div class="text-center">
								<p
									class="text-sm mb-2"
									style={{ color: "var(--theme-muted)" }}
								>
									> Interactive Linux-style terminal with <span
										class="font-semibold"
										style={{
											color: "var(--theme-primary)",
										}}>30+ commands</span
									>
								</p>
								<p
									class="text-xs"
									style={{ color: "var(--theme-muted)" }}
								>
									Navigate: <span
										style={{ color: "var(--theme-info)" }}
										>cd projects</span
									> | <span
										style={{
											color: "var(--theme-secondary)",
										}}>cd blogs</span
									> | <span
										style={{ color: "var(--theme-accent)" }}
										>cd profile</span
									>
								</p>
							</div>
						</div>
					</div>
				</div>
			</main>
			<Footer />
		</div>
	</body>
</html>
<style>
	@keyframes blink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0; }
	}
	.cursor-blink {
		animation: blink 1s step-start infinite;
		color: var(--theme-primary);
	}
	input[type="text"] {
		caret-color: #22c55e;
	}
</style>
<script define:vars={{ resumePdfPath, terminalResumeLines, terminalHostname: terminalConfig.hostname }}>
	// ── Typing animation on welcome title ──────────────────────────────────
	const welcomeTitle = document.getElementById("welcome-title");
	if (welcomeTitle) {
		const fullText = welcomeTitle.textContent?.trim() ?? "";
		welcomeTitle.textContent = "";
		const cursor = document.createElement("span");
		cursor.className = "cursor-blink";
		cursor.textContent = "█";
		welcomeTitle.appendChild(cursor);
		let i = 0;
		const typeInterval = setInterval(() => {
			if (i < fullText.length) {
				welcomeTitle.insertBefore(document.createTextNode(fullText[i]), cursor);
				i++;
			} else {
				clearInterval(typeInterval);
			}
		}, 40);
	}

	// ── Terminal input logic ───────────────────────────────────────────────
	const inputCapture = document.getElementById("terminal-input");
	if (inputCapture) {
		const commandHistory = [];
		let historyIndex = -1;
		let activeGame = null;
		let gameState = null;

		inputCapture.focus();
		document.addEventListener("click", (event) => {
			const target = event.target;
			if (!(target instanceof HTMLElement)) return;

			const contactPanel = document.getElementById("contact-panel");
			if (contactPanel?.classList.contains("is-open")) {
				return;
			}

			if (target.closest("#terminal-container")) {
				inputCapture.focus();
			}
		});

		function clearTerminal() {
			const commandOutput = document.getElementById("command-output");
			if (commandOutput) {
				commandOutput.innerHTML = "";
				commandOutput.style.display = "none";
			}
			inputCapture.value = "";
		}

		function showHomeState(commandStr) {
			const welcomeBox = document.getElementById("welcome-box");
			if (welcomeBox) {
				welcomeBox.style.display = "block";
			}

			const commandOutput = document.getElementById("command-output");
			if (commandOutput) {
				commandOutput.innerHTML = "";
				commandOutput.style.display = "none";
			}

			renderOutput([
				"Returned to home.",
				"Type 'cd profile' to view profile details or 'help' for commands.",
				"",
			], "var(--theme-muted)", commandStr);
		}

		function exitGame(gameName) {
			activeGame = null;
			gameState = null;
			renderOutput([`Exited ${gameName}.`, ""], "var(--theme-muted)", "exit");
		}

		function startNumberGuess(commandStr) {
			activeGame = "numberguess";
			gameState = {
				target: Math.floor(Math.random() * 100) + 1,
				attempts: 0,
				maxAttempts: 7,
			};
			renderOutput([
				"Number Guess started.",
				"I'm thinking of a number from 1 to 100.",
				"You have 7 attempts.",
				"Type a number to guess or 'exit' to quit.",
				"",
			], "var(--theme-warning)", commandStr);
		}

		function startRps(commandStr) {
			activeGame = "rps";
			gameState = { wins: 0, losses: 0, draws: 0 };
			renderOutput([
				"Rock Paper Scissors started.",
				"Type: rock, paper, or scissors.",
				"Type 'exit' to quit.",
				"",
			], "var(--theme-accent)", commandStr);
		}

		function startWordle(commandStr) {
			const words = ["react", "astro", "linux", "stack", "debug", "logic", "cisco", "shell"];
			activeGame = "wordle";
			gameState = {
				secret: words[Math.floor(Math.random() * words.length)],
				attempts: 0,
				maxAttempts: 6,
			};
			renderOutput([
				"Wordle started.",
				"Guess the 5-letter word in 6 tries.",
				"Feedback: [G] right spot, [Y] wrong spot, [_] absent.",
				"Type a 5-letter guess or 'exit' to quit.",
				"",
			], "var(--theme-secondary)", commandStr);
		}

		function handleActiveGame(commandStr) {
			const guess = commandStr.toLowerCase();

			if (guess === "exit" || guess === "quit") {
				exitGame(activeGame);
				return true;
			}

			if (activeGame === "numberguess") {
				const value = Number.parseInt(guess, 10);
				if (Number.isNaN(value) || value < 1 || value > 100) {
					renderOutput(["Enter a valid number between 1 and 100.", ""], "var(--theme-error)", commandStr);
					return true;
				}

				gameState.attempts += 1;
				if (value === gameState.target) {
					renderOutput([
						`Correct. You guessed it in ${gameState.attempts} attempt(s).`,
						"Type 'numberguess' to play again.",
						"",
					], "var(--theme-success)", commandStr);
					activeGame = null;
					gameState = null;
					return true;
				}

				if (gameState.attempts >= gameState.maxAttempts) {
					renderOutput([
						`Out of attempts. The number was ${gameState.target}.`,
						"Type 'numberguess' to play again.",
						"",
					], "var(--theme-error)", commandStr);
					activeGame = null;
					gameState = null;
					return true;
				}

				renderOutput([
					value < gameState.target ? "Too low." : "Too high.",
					`${gameState.maxAttempts - gameState.attempts} attempt(s) left.`,
					"",
				], "var(--theme-warning)", commandStr);
				return true;
			}

			if (activeGame === "rps") {
				const choices = ["rock", "paper", "scissors"];
				if (!choices.includes(guess)) {
					renderOutput(["Type rock, paper, or scissors.", ""], "var(--theme-error)", commandStr);
					return true;
				}

				const cpu = choices[Math.floor(Math.random() * choices.length)];
				if (guess === cpu) {
					gameState.draws += 1;
					renderOutput([
						`You: ${guess}`,
						`CPU: ${cpu}`,
						"Draw.",
						`Score W:${gameState.wins} L:${gameState.losses} D:${gameState.draws}`,
						"",
					], "var(--theme-info)", commandStr);
					return true;
				}

				const win =
					(guess === "rock" && cpu === "scissors") ||
					(guess === "paper" && cpu === "rock") ||
					(guess === "scissors" && cpu === "paper");

				if (win) {
					gameState.wins += 1;
				} else {
					gameState.losses += 1;
				}

				renderOutput([
					`You: ${guess}`,
					`CPU: ${cpu}`,
					win ? "You win." : "CPU wins.",
					`Score W:${gameState.wins} L:${gameState.losses} D:${gameState.draws}`,
					"",
				], win ? "var(--theme-success)" : "var(--theme-error)", commandStr);
				return true;
			}

			if (activeGame === "wordle") {
				if (guess.length !== 5) {
					renderOutput(["Enter exactly 5 letters.", ""], "var(--theme-error)", commandStr);
					return true;
				}

				gameState.attempts += 1;
				const feedback = guess.split("").map((char, index) => {
					if (gameState.secret[index] === char) return `[G] ${char}`;
					if (gameState.secret.includes(char)) return `[Y] ${char}`;
					return `[_] ${char}`;
				});

				if (guess === gameState.secret) {
					renderOutput([
						feedback.join(" "),
						`Solved in ${gameState.attempts} attempt(s).`,
						"Type 'wordle' to play again.",
						"",
					], "var(--theme-success)", commandStr);
					activeGame = null;
					gameState = null;
					return true;
				}

				if (gameState.attempts >= gameState.maxAttempts) {
					renderOutput([
						feedback.join(" "),
						`No attempts left. The word was '${gameState.secret}'.`,
						"Type 'wordle' to play again.",
						"",
					], "var(--theme-error)", commandStr);
					activeGame = null;
					gameState = null;
					return true;
				}

				renderOutput([
					feedback.join(" "),
					`${gameState.maxAttempts - gameState.attempts} attempt(s) left.`,
					"",
				], "var(--theme-secondary)", commandStr);
				return true;
			}

			return false;
		}

		inputCapture.addEventListener("keydown", (e) => {
			if (e.key === "Enter") {
				const welcomeBox = document.getElementById("welcome-box");
				if (welcomeBox) welcomeBox.style.display = "none";

				e.preventDefault();
				const commandStr = inputCapture.value.trim();
				if (!commandStr) return;

				commandHistory.push(commandStr);
				historyIndex = commandHistory.length;

				const command = commandStr.toLowerCase();
				if (activeGame && handleActiveGame(commandStr)) {
					inputCapture.value = "";
					return;
				}

				// ── Navigation ────────────────────────────────────────────
				if (command === "cd projects" || command === "cd project" || command === "./projects" || command === "./ projects" || command === "projects") {
					window.location.href = "/projects";

				} else if (command === "cd blogs" || command === "cd blog" || command === "./blogs" || command === "./ blogs" || command === "blogs") {
					window.location.href = "/blogs";

				} else if (command === "resume" || command === "cv" || command === "open resume" || command === "./resume" || command === "./ resume") {
					window.location.href = "/resume";

				} else if (command === "cd" || command === "cd ~" || command === "cd~" || command === "cd home") {
					showHomeState(commandStr);

				} else if (command === "cd profile") {
					renderOutput([
						"┌──────────────────────────────────────────────────┐",
						"│                  👤  PROFILE                      │",
						"└──────────────────────────────────────────────────┘",
						"",
						"  Name       : Rey Lorenz Cabanog",
						"  Username   : reycxz",
						"  Title      : Full Stack Developer & Cyber Security Enthusiast",
						"             : Computer Engineering Student",
						"  Location   : Navotas City, PH",
						"  Email      : reylorenzc@gmail.com",
						"",
						"  Bio        : I'm a passionate developer who loves creating",
						"             : innovative solutions and learning new technologies.",
						"",
						"  🔭 Current Focus:",
						"    • Developing a multi-agency booking platform using Laravel",
						"    • Advancing in SOC Operations and Digital Forensics (DFIR)",
						"    • Contributing to open source projects",
						"    • Completing CE degree at TIP Manila (Class of 2027)",
						"",
						"  🌐 Social Links:",
						"    • GitHub   : https://github.com/reycxz",
						"    • LinkedIn : https://www.linkedin.com/in/reylorenzc/",
						"    • Ping Me  : Use 'ping me' or 'ping iamrey.dev'",
						"",
						"  ⚡ Fun Fact : I am a working student. I juggle work and class.",
						""
					], "var(--theme-primary)", commandStr);

				} else if (command === "cd cert" || command === "cd certs" || command === "cert" || command === "certs") {
					renderOutput([
						"┌──────────────────────────────────────────────────┐",
						"│               📜  CERTIFICATIONS                 │",
						"└──────────────────────────────────────────────────┘",
						"",
						"  • Digital Forensics & Incident Investigation - Red Team Leaders",
						"    Adding to my DFIR knowledge. Excited to earn this certification...",
						"",
						"  • SOC Operations & DFIR - Blue Cape Security",
						"    Completed an 8-hour intensive on SOC operations and DFIR.",
						"",
						"  • CCNA 1 Certificate of Course Completion",
						"    Cisco Networking Academy - Introduction to Networks",
						"",
						"  • Introduction to Satellites and Remote Sensing",
						"    Completed Sept 23, 2024",
						"",
						"  • Smarter Pest Identification Technology (SPIDTECH)",
						"    Completed Sept 27, 2024",
						"",
						"  • Endpoint Security Certificate",
						"    Cisco Networking Academy - Oct 14, 2025",
						"",
						"  • Cyber Threat Management Certificate",
						"    Cisco Networking Academy - Sept 25, 2025",
						"",
						"  • CCNA 2 Certificate of Course Completion",
						"    Cisco Networking Academy",
						""
					], "var(--theme-info)", commandStr);

				// ── About ─────────────────────────────────────────────────
				} else if (command === "whoami") {
					renderOutput([
						"reycxz — Rey Lorenz Cabanog",
						"Full Stack Developer & Cyber Security Enthusiast",
						"Computer Engineering Student @ TIP Manila",
						"Navotas City, PH  |  reylorenzc@gmail.com",
						""
					], "var(--theme-primary)", commandStr);

				} else if (command === "cat resume.txt") {
					renderOutput(terminalResumeLines, "var(--theme-outputText)", commandStr);

				} else if (command === "neofetch") {
					renderOutput([
						"  reycxz@iamrey.dev",
						"  -----------------",
						"  User   : Rey Lorenz Cabanog",
						"  Role   : Full Stack Dev & CySec Enthusiast",
						"  School : TIP Manila — CE (Class of 2027)",
						"  Loc    : Navotas City, PH",
						"  OS     : Linux x86_64",
						"  Shell  : bash",
						"  Theme  : Dark Terminal",
						"  Pkgs   : 392 (npm)",
						"  GitHub : github.com/reycxz",
						"  Memory : 1024MB / 8192MB",
						""
					], "var(--theme-info)", commandStr);

				} else if (command === "skills") {
					renderOutput([
						"  Languages  : PHP, JavaScript, TypeScript, Python, C++, SQL",
						"  Frameworks : Laravel, React.js, Astro, Tailwind CSS",
						"  Tools      : Git, Docker, Linux, Cisco Networking",
						"  Security   : DFIR, SOC Operations, Network Security",
						""
					], "var(--theme-secondary)", commandStr);

				// ── Contact ───────────────────────────────────────────────
				} else if (command === "contact") {
					renderOutput([
						"┌──────────────────────────────────────────────────┐",
						"│                  📬  CONTACT                      │",
						"└──────────────────────────────────────────────────┘",
						"",
						"  GitHub   : https://github.com/reycxz",
						"  LinkedIn : https://www.linkedin.com/in/reylorenzc/",
						"  Email    : reylorenzc@gmail.com",
						"  Tip      : type 'ping me' to open the contact panel",
						"",
						"  You can also type 'open github' or 'open linkedin'.",
						""
					], "var(--theme-info)", commandStr);

				} else if (command === "ping me" || command === "ping iamrey.dev" || command === "open contact") {
					window.dispatchEvent(new CustomEvent("contact-panel:open", { detail: { tab: "contact" } }));
					renderOutput(["  ↗ Opening contact panel...", ""], "var(--theme-primary)", commandStr);

				} else if (command === "ask rey" || command === "chat") {
					window.dispatchEvent(new CustomEvent("contact-panel:open", { detail: { tab: "assistant" } }));
					renderOutput(["  ↗ Opening Rey assistant...", ""], "var(--theme-primary)", commandStr);

				} else if (command === "open github" || command === "gh" || command === "github" || command === "git" || command === "./gh" || command === "git://gh") {
					window.open("https://github.com/reycxz", "_blank", "noopener,noreferrer");
					renderOutput(["  ↗ Opening GitHub profile in a new tab...", ""], "var(--theme-primary)", commandStr);

				} else if (command === "open linkedin") {
					window.open("https://www.linkedin.com/in/reylorenzc/", "_blank", "noopener,noreferrer");
					renderOutput(["  ↗ Opening LinkedIn profile in a new tab...", ""], "var(--theme-primary)", commandStr);

				} else if (command === "open messenger" || command === "messenger" || command === "@messenger") {
					window.dispatchEvent(new CustomEvent("contact-panel:open", { detail: { tab: "contact" } }));
					renderOutput(["  ↗ Opening contact panel...", ""], "var(--theme-primary)", commandStr);

				} else if (command === "download resume") {
					window.open(resumePdfPath, "_blank", "noopener,noreferrer");
					renderOutput(["  ↗ Opening resume PDF in a new tab...", ""], "var(--theme-primary)", commandStr);

				// ── Misc ──────────────────────────────────────────────────
				} else if (command === "history") {
					const hist = commandHistory.slice(0, -1);
					if (hist.length === 0) {
						renderOutput(["  No command history yet.", ""], "var(--theme-muted)", commandStr);
					} else {
						renderOutput(
							hist.map((cmd, i) => `  ${String(i + 1).padStart(3)}  ${cmd}`).concat([""]),
							"var(--theme-outputText)", commandStr
						);
					}

				} else if (command === "shortcuts" || command === "nav") {
					renderOutput([
						"Header shortcuts:",
						"  resume     - Open the resume page",
						"  blogs      - Open blog posts",
						"  projects   - Open projects page",
						"  ping me    - Open the contact panel",
						"  gh         - Open GitHub",
						"",
						"These match the labels shown in the top navigation.",
						"",
					], "var(--theme-info)", commandStr);

				} else if (command === "games") {
					renderOutput([
						"Available terminal games:",
						"  numberguess  - Guess a number from 1 to 100 in 7 tries",
						"  rps          - Rock, Paper, Scissors against CPU",
						"  wordle       - Guess the 5-letter word in 6 tries",
						"",
						"During a game, type 'exit' to quit back to the terminal.",
						"",
					], "var(--theme-warning)", commandStr);

				} else if (command === "numberguess") {
					startNumberGuess(commandStr);

				} else if (command === "rps") {
					startRps(commandStr);

				} else if (command === "wordle") {
					startWordle(commandStr);

				} else if (command === "help" || command === "h") {
					renderOutput([
						"  Available commands:",
						"",
						"  Navigation:",
						"   cd projects      — Browse GitHub projects",
						"   cd blogs         — Browse blog posts",
						"   ls               — List available sections",
						"",
						"  About:",
						"   whoami           — Quick identity summary",
						"   cd profile       — Detailed profile card",
						"   cd cert          — View certifications",
						"   cat resume.txt   — View resume",
						"   resume / cv      — Open printable resume page",
						"   skills           — List skills & technologies",
						"   neofetch         — System / profile info",
						"",
						"  Contact:",
						"   contact          — Show all contact links",
						"   ping me          — Open the contact panel",
						"   ask rey / chat   — Open the Rey assistant",
						"   open github      — Open GitHub in new tab",
						"   open linkedin    — Open LinkedIn in new tab",
						"   open contact     — Open the contact panel",
						"   download resume  — Open original resume PDF",
						"",
						"  Misc:",
						"   history          — Show command history",
						"   shortcuts / nav  — Show top navigation aliases",
						"   games            — List available terminal games",
						"   numberguess      — Start number guessing game",
						"   rps              — Start rock paper scissors",
						"   wordle           — Start 5-letter word game",
						"   joke             — Random dev joke",
						"   clear / cls      — Clear terminal",
						"   help / h         — Show this message",
						""
					], "var(--theme-outputText)", commandStr);

				} else if (command === "clear" || command === "cls") {
					clearTerminal();
					return;

				} else if (command === "ls" || command === "ll") {
					renderOutput([
						"drwxr-xr-x  user  blogs/",
						"drwxr-xr-x  user  certs/",
						"drwxr-xr-x  user  games/",
						"drwxr-xr-x  user  projects/",
						"-rw-r--r--  user  resume.cv",
						"-rw-r--r--  user  profile",
						"-rw-r--r--  user  resume.txt",
						""
					], "var(--theme-info)", commandStr);

				} else if (command === "..") {
					renderOutput(["bash: ..: command not found (already at root)"], "var(--theme-warning)", commandStr);

				} else if (command === "joke") {
					const jokes = [
						"Why do programmers prefer dark mode? Because light attracts bugs.",
						"I've got a really good UDP joke, but I don't know if you'll get it.",
						"There are 10 types of people: those who understand binary, and those who don't.",
						"A SQL query walks into a bar, walks up to two tables and asks... 'Can I join you?'",
						"How many programmers does it take to change a light bulb? None, that's a hardware problem.",
						"A SEO expert walks into a bar, bars, pub, tavern, public house, Irish pub, drinks, beer, alcohol.",
						"Why did the programmer quit? Because he didn't get arrays.",
						"Why do Java devs wear glasses? Because they can't C#.",
						"The most used language in programming? Profanity.",
						"An IPv6 packet walks into a bar. Nobody talks to him.",
						"Why was the JS developer sad? He didn't Node how to Express himself.",
						"Why did the router break up with the modem? There was no connection.",
						"Knock, knock. Who's there? ...very long pause... Java.",
						"What's the best thing about boolean dreams? They're either true or false.",
						"Why did the web developer leave the restaurant? Terrible table layout.",
						"If you listen to a shell, you can hear: rm -rf /",
						"Why did the hacker get chilly? He left the Windows open.",
						"What's a cyber expert's favorite animal? A phishing cat.",
						"I'd tell you a joke about DNS, but it might take 24-48 hours to propagate.",
						"Two hard things in CS: cache invalidation, naming things, and off-by-one errors."
					];
					let jokeIndex;
					do {
						jokeIndex = Math.floor(Math.random() * jokes.length);
					} while (jokeIndex === window.lastJokeIndex);
					window.lastJokeIndex = jokeIndex;
					renderOutput([jokes[jokeIndex], ""], "var(--theme-accent)", commandStr);

				} else {
					renderOutput([`bash: ${commandStr}: command not found`, ""], "var(--theme-error)", commandStr);
				}

				inputCapture.value = "";

			} else if (e.key === "ArrowUp") {
				e.preventDefault();
				if (historyIndex > 0) {
					historyIndex--;
					inputCapture.value = commandHistory[historyIndex];
				}
			} else if (e.key === "ArrowDown") {
				e.preventDefault();
				if (historyIndex < commandHistory.length - 1) {
					historyIndex++;
					inputCapture.value = commandHistory[historyIndex];
				} else {
					historyIndex = commandHistory.length;
					inputCapture.value = "";
				}
			} else if (e.key === "l" && e.ctrlKey) {
				e.preventDefault();
				clearTerminal();
			} else if (e.key === "Tab") {
				e.preventDefault();
				const current = inputCapture.value.toLowerCase();
				const commands = [
					"help", "whoami", "contact", "neofetch", "skills", "joke", "history",
					"shortcuts", "nav",
					"clear", "cat resume.txt", "resume", "cv", "open resume", "games",
					"numberguess", "rps", "wordle", "cd projects", "cd blogs", "cd profile", "cd cert", "cd ~",
					"projects", "blogs", "certs", "cert", "./projects", "./blogs", "./resume", "gh", "git", "ping me", "ping iamrey.dev", "ask rey", "chat", "messenger", "@messenger",
					"ls", "ll", "open github", "open linkedin", "open contact", "open messenger", "download resume", "exit"
				];
				const match = commands.find(cmd => cmd.startsWith(current));
				if (match) inputCapture.value = match;
			}
		});

		function renderOutput(lines, defaultColor, cmdString) {
			const commandOutput = document.getElementById("command-output");
			if (!commandOutput) return;

			commandOutput.style.display = "block";

			const outputDiv = document.createElement("div");
			outputDiv.className = "space-y-2 mt-4";

			if (cmdString) {
				const cmdStrDiv = document.createElement("div");
				cmdStrDiv.className = "pl-2 sm:pl-4 text-sm sm:text-base mb-1 flex flex-wrap items-center gap-1 min-w-0";

				const promptUser = document.createElement("span");
				promptUser.style.color = "var(--theme-promptUser)";
				promptUser.textContent = `user@${terminalHostname}`;

				const promptColon = document.createElement("span");
				promptColon.style.color = "var(--theme-text)";
				promptColon.textContent = ":";

				const promptPath = document.createElement("span");
				promptPath.style.color = "var(--theme-promptPath)";
				promptPath.textContent = "~";

				const promptSymbol = document.createElement("span");
				promptSymbol.style.color = "var(--theme-promptSymbol)";
				promptSymbol.textContent = "$";

				const commandText = document.createElement("span");
				commandText.style.color = "var(--theme-commandText)";
				commandText.textContent = cmdString;

				cmdStrDiv.append(promptUser, promptColon, promptPath, promptSymbol, commandText);
				outputDiv.appendChild(cmdStrDiv);
			}

			const innerDiv = document.createElement("div");
			innerDiv.className = "pl-2 sm:pl-4 text-sm sm:text-base space-y-1";

			lines.forEach(line => {
				const lineDiv = document.createElement("div");
				lineDiv.className = "break-words min-w-0";
				lineDiv.style.color = defaultColor || "var(--theme-outputText)";
				const pre = document.createElement("pre");
				pre.style.fontFamily = "inherit";
				pre.style.margin = "0";
				pre.style.whiteSpace = "pre-wrap";
				pre.style.overflowWrap = "anywhere";
				pre.style.wordBreak = "break-word";
				pre.style.lineHeight = "1.6";
				pre.textContent = line;
				lineDiv.appendChild(pre);
				innerDiv.appendChild(lineDiv);
			});

			outputDiv.appendChild(innerDiv);
			commandOutput.appendChild(outputDiv);

			const container = document.getElementById("terminal-container");
			if (container) container.scrollTop = container.scrollHeight;
		}
	}
</script>
