---
import { getLanguageColor } from "../utils/theme";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import githubData from "../data/github-projects.json" assert { type: "json" };
import profileConfig from "../../profile.config";
import FeatureRepo from "../components/FeatureRepo.astro";
import ProjectsUpdateDate from "../components/ProjectsUpdateDate.astro";
import AllRepo from "../components/AllRepo.astro";
import type { ProjectItem } from "../types";

function normalizeGitHubProject(repo: any): ProjectItem {
    return {
        name: repo.name,
        description: repo.description ?? null,
        html_url: repo.html_url ?? repo.url ?? null,
        homepage: repo.homepage ?? repo.homepageUrl ?? null,
        primaryLanguages: repo.primaryLanguages ?? (repo.primaryLanguage?.name ? [repo.primaryLanguage.name] : []),
        stargazers_count: repo.stargazers_count ?? repo.stargazerCount ?? 0,
        forks_count: repo.forks_count ?? repo.forkCount ?? 0,
        updated_at: repo.updated_at ?? repo.updatedAt ?? repo.pushed_at ?? repo.pushedAt ?? repo.createdAt ?? "",
        source: "github",
        sourceLabel: "GitHub",
    };
}

function normalizePersonalProject(project: (typeof profileConfig.projects.personalProjects)[number]): ProjectItem {
    return {
        name: project.name,
        description: project.description,
        html_url: project.url ?? null,
        homepage: project.liveUrl ?? null,
        primaryLanguages: project.primaryLanguages,
        stargazers_count: 0,
        forks_count: 0,
        updated_at: project.updatedAt,
        source: "personal",
        sourceLabel: "Personal",
    };
}

const githubProjects = (githubData.repositories ?? []).map(normalizeGitHubProject);
const featuredGitHubProjects = (githubData.featured ?? []).map(normalizeGitHubProject);
const personalProjects = (profileConfig.projects.personalProjects ?? []).map(normalizePersonalProject);
const featuredPersonalProjects = (profileConfig.projects.personalProjects ?? [])
    .filter((project) => project.featured)
    .map(normalizePersonalProject);
const featuredProjects = [...featuredPersonalProjects, ...featuredGitHubProjects];
const allProjects = [...personalProjects, ...githubProjects];
const allLanguages = [...new Set(allProjects.flatMap((project) => project.primaryLanguages ?? []))].sort((a, b) => a.localeCompare(b));
---

<!doctype html>
<html lang="en" data-theme="dark">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    </head>
    <body>
        <div
            class="min-h-screen flex flex-col"
            style={{
                backgroundColor: "var(--theme-background)",
                color: "var(--theme-text)",
            }}
        >
            <Header />
            <div
                class="min-h-screen font-mono pb-8 md:pb-16"
                style={{
                    backgroundColor: "var(--theme-background)",
                    color: "var(--theme-text)",
                }}
            >
                <div class="safe-px max-w-6xl mx-auto py-4 sm:py-8 px-3 sm:px-4">
                    {/* Terminal navigation */}
                    <div class="mb-4 sm:mb-6">
                        <div
                            class="bg-gray-900 border border-gray-700 rounded-lg p-3 sm:p-4"
                        >
                            <div
                                class="flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-2 w-full"
                            >
                                <div
                                    class="input-shell flex items-center gap-1 text-xs sm:text-sm w-full min-w-0 px-2"
                                >
                                    <span class="text-blue-400 hidden sm:inline"
                                        >user@localhost</span
                                    >
                                    <span class="text-white hidden sm:inline"
                                        >:</span
                                    >
                                    <span class="text-blue-600 hidden sm:inline"
                                        >~/projects</span
                                    >
                                    <span class="text-white">$ </span>
                                    <input
                                        type="text"
                                        id="projects-terminal-input"
                                        class="bg-transparent border-none outline-none flex-1 min-w-0 font-mono text-sm sm:text-sm text-green-400 placeholder-gray-500 py-2"
                                        placeholder="Type home, blogs, or resume"
                                        autofocus
                                    />
                                </div>
                                <p class="text-gray-400 text-xs sm:text-sm">
                                    Quick navigation
                                </p>
                            </div>
                        </div>
                    </div>

                    {/* Terminal window */}
                    <div
                        class="bg-gray-900 border border-gray-700 rounded-t-lg"
                    >
                        <div
                            class="flex flex-col sm:flex-row sm:items-center sm:justify-between p-3 sm:p-4 border-b border-gray-700 space-y-2 sm:space-y-0"
                        >
                            <div class="flex items-center space-x-2">
                                <div class="w-3 h-3 bg-red-500 rounded-full">
                                </div>
                                <div class="w-3 h-3 bg-yellow-500 rounded-full">
                                </div>
                                <div class="w-3 h-3 bg-green-500 rounded-full">
                                </div>
                                <span
                                    class="text-gray-400 text-xs sm:text-sm ml-4"
                                    >Projects</span
                                >
                            </div>
                            <div class="text-gray-500 text-xs">Selected work</div>
                        </div>
                    </div>

                    <div
                        class="bg-black border-x border-b border-gray-700 rounded-b-lg p-4 sm:p-8 overflow-hidden"
                    >
                        {/* Header */}
                        <div class="mb-6 border-b border-gray-800 pb-4">
                            <h1
                                class="text-2xl sm:text-3xl font-bold mb-4 text-green-400"
                            >
                                Projects
                            </h1>
                            <p class="text-sm text-gray-400 mb-4">
                                Browse featured work, personal builds, and GitHub repositories.
                            </p>
                            <div
                                class="flex flex-wrap items-center gap-3 text-xs sm:text-sm"
                            >
                                <span class="text-blue-400">👤 @{githubData.user.login}</span>
                                <span class="text-yellow-400">📁 {allProjects.length} total projects</span>
                                <span class="text-purple-400">🐙 {githubProjects.length} GitHub repos</span>
                                <span class="text-green-400">🧩 {personalProjects.length} personal projects</span>
                            </div>
                        </div>

                        {/* GitHub Stats */}
                        <div class="grid grid-cols-2 xl:grid-cols-4 gap-3 sm:gap-4 mb-8">
                            <div
                                class="bg-gray-800 border border-gray-600 rounded-lg p-4 text-center"
                            >
                                <div class="text-blue-400 text-2xl font-bold">
                                    {allProjects.length}
                                </div>
                                <div class="text-gray-400 text-sm">Projects</div>
                            </div>
                            <div
                                class="bg-gray-800 border border-gray-600 rounded-lg p-4 text-center"
                            >
                                <div class="text-yellow-400 text-2xl font-bold">
                                    {githubProjects.length}
                                </div>
                                <div class="text-gray-400 text-sm">
                                    GitHub Repos
                                </div>
                            </div>
                            <div
                                class="bg-gray-800 border border-gray-600 rounded-lg p-4 text-center"
                            >
                                <div class="text-purple-400 text-2xl font-bold">
                                    {personalProjects.length}
                                </div>
                                <div class="text-gray-400 text-sm">
                                    Personal Projects
                                </div>
                            </div>
                            <div
                                class="bg-gray-800 border border-gray-600 rounded-lg p-4 text-center"
                            >
                                <div class="text-green-400 text-2xl font-bold">
                                    {allLanguages.length}
                                </div>
                                <div class="text-gray-400 text-sm">
                                    Languages
                                </div>
                            </div>
                        </div>

                        {/* All Languages Section */}
                        <div class="mb-6">
                            <h2
                                class="text-lg font-semibold text-green-400 mb-3"
                            >
                                Filter By Language
                            </h2>
                            <div
                                class="bg-gray-800 border border-gray-600 rounded-lg p-4"
                            >
                                <p class="text-gray-500 text-xs mb-3">Choose a language to narrow the list.</p>
                                <div class="mobile-scroll flex gap-2 overflow-x-auto pb-2" id="lang-filter-bar">
                                    <button
                                        data-lang="all"
                                        class="lang-filter-btn touch-target flex-none flex items-center gap-2 bg-green-800 border border-green-500 px-3 py-2 rounded-lg cursor-pointer text-left transition-all whitespace-nowrap"
                                    >
                                        <span class="text-gray-200 text-sm font-semibold">All</span>
                                    </button>
                                    {
                                        allLanguages.map(
                                            (language) => (
                                                <button
                                                    data-lang={language.toLowerCase()}
                                                    class="lang-filter-btn touch-target flex-none flex items-center gap-2 bg-gray-700 px-3 py-2 rounded-lg cursor-pointer text-left transition-all hover:bg-gray-600 whitespace-nowrap"
                                                >
                                                    <div
                                                        class="w-3 h-3 rounded-full flex-shrink-0"
                                                        style={{
                                                            backgroundColor:
                                                                getLanguageColor(
                                                                    language,
                                                                ),
                                                        }}
                                                    />
                                                    <span class="text-gray-300 text-sm">
                                                        {language}
                                                    </span>
                                                </button>
                                            ),
                                        )
                                    }
                                </div>
                                <div class="mt-3 text-gray-400 text-xs">
                                    {allLanguages.length} languages available
                                </div>
                            </div>
                        </div>
                        <FeatureRepo featuredRepo={featuredProjects} />
                        <AllRepo allRepo={allProjects} />
                    </div>
                    <ProjectsUpdateDate lastUpdated={githubData.lastUpdated} />
                </div>
                <Footer />
             </div>
        </div>
    </body>
</html>

<script>
    // ── Language filter ────────────────────────────────────────────────────
    const filterBar = document.getElementById("lang-filter-bar");
    const repoCards = document.querySelectorAll(".repo-card");
    let activeFilter = "all";

    function applyFilter(lang) {
        activeFilter = lang;

        // Update button styles
        document.querySelectorAll(".lang-filter-btn").forEach(btn => {
            const isActive = btn.dataset.lang === lang;
            btn.style.backgroundColor = isActive ? "rgb(22 101 52)" : "";
            btn.style.borderColor = isActive ? "rgb(34 197 94)" : "";
            btn.style.borderWidth = isActive ? "1px" : "";
            btn.style.borderStyle = isActive ? "solid" : "";
        });

        // Show/hide repo cards
        let visibleCount = 0;
        repoCards.forEach(card => {
            const langs = card.dataset.languages ?? "";
            const visible = lang === "all" || langs.split(",").includes(lang);
            card.style.display = visible ? "" : "none";
            if (visible) visibleCount++;
        });

        // Update no-results message
        let noResults = document.getElementById("no-results-msg");
        if (visibleCount === 0) {
            if (!noResults) {
                noResults = document.createElement("p");
                noResults.id = "no-results-msg";
                noResults.className = "text-gray-500 text-sm col-span-full py-4";
                noResults.textContent = "No repositories found for this language.";
                document.getElementById("all-repo-grid")?.appendChild(noResults);
            }
        } else if (noResults) {
            noResults.remove();
        }
    }

    filterBar?.addEventListener("click", (e) => {
        const btn = e.target.closest(".lang-filter-btn");
        if (btn?.dataset.lang) applyFilter(btn.dataset.lang);
    });

    // ── Terminal input ─────────────────────────────────────────────────────
    const input = document.getElementById("projects-terminal-input");
    if (input) {
        input.focus();
        document.addEventListener("click", (e) => {
            if (e.target.closest('.min-h-screen.font-mono')) {
                input.focus();
            }
        });

        input.addEventListener("keydown", (e) => {
            if (e.key === "Enter") {
                const commandStr = input.value.trim();
                const command = commandStr.toLowerCase();

                if (command === "home" || command === "cd ~" || command === "cd" || command === "cd profile" || command === "cd home") {
                    window.location.href = "/";
                } else if (command === "cd blogs" || command === "cd blog" || command === "blogs") {
                    window.location.href = "/blogs";
                } else if (command === "resume" || command === "cv" || command === "cd resume") {
                    window.location.href = "/resume";
                } else if (command === "clear" || command === "cls") {
                    input.value = "";
                } else {
                    input.value = "";
                }
            }
        });
    }
</script>
