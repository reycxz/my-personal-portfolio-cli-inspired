---
import ContactPanel from "./ContactPanel.astro";
import { NAVIGATION } from "../consts";
import "../styles/global.css";

const date = new Date();
const dateString = date.toLocaleDateString();
const timeString = date.toLocaleTimeString();
---

<nav
	class="border-b font-mono"
	style={{
		backgroundColor: "var(--theme-background)",
		borderColor: "var(--theme-border)",
	}}
>
	<div class="safe-px max-w-screen-xl mx-auto px-3 sm:px-4 py-2 sm:py-3">
		{/* Terminal-style navigation */}
		<div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
			{/* Left side - Terminal prompt */}
			<div class="flex items-center justify-between gap-3 text-xs sm:text-sm md:justify-start">
				<a
					href={NAVIGATION.brandUrl}
					class="font-bold text-sm sm:text-base hover:opacity-75 transition-opacity shrink-0"
					style={{ color: "var(--theme-primary)" }}
				>
					{NAVIGATION.brandName}
				</a>
			</div>

			{/* Center - System info */}
			{
				NAVIGATION.systemInfo.showDateTime && (
					<div
						class="hidden lg:flex items-center space-x-4 text-xs"
						style={{ color: "var(--theme-muted)" }}
					>
						<span>{NAVIGATION.systemInfo.shell}</span>
						<span>•</span>
						<span
							id="clock"
							style={{ color: "var(--theme-primary)" }}
						>
							{dateString} • {timeString}
						</span>
					</div>
				)
			}
			<script>
				const el = document.getElementById("clock");
				setInterval(() => {
					if (el) {
						el.textContent =
							new Date().toLocaleDateString() +
							" • " +
							new Date().toLocaleTimeString();
					}
				}, 1000);
			</script>

			{/* Right side - Navigation commands & Theme selector */}
			<div
				class="flex flex-wrap items-center gap-2 sm:gap-3 text-xs sm:text-sm md:justify-end"
			>
				<button
					id="themeToggle"
					class="theme-toggle touch-target rounded-full text-xs font-mono hover:opacity-75 transition-opacity"
					style="background-color: var(--theme-accent); color: var(--theme-background);"
					aria-label="Toggle theme"
					title="Toggle theme"
				>
					<svg
						class="theme-toggle__icon"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="1.8"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path d="M12 3v2.5" />
						<path d="M12 18.5V21" />
						<path d="M4.93 4.93l1.77 1.77" />
						<path d="M17.3 17.3l1.77 1.77" />
						<path d="M3 12h2.5" />
						<path d="M18.5 12H21" />
						<path d="M4.93 19.07l1.77-1.77" />
						<path d="M17.3 6.7l1.77-1.77" />
						<path d="M15.5 12a3.5 3.5 0 1 1-7 0a3.5 3.5 0 0 1 7 0Z" />
					</svg>
				</button>

				{
					NAVIGATION.links.map((link, index) => (
						<span>
							{index > 0 && (
								<span
									class="hidden sm:inline"
									style={{ color: "var(--theme-border)" }}
								>
									|
								</span>
							)}
							{link.path === "#contact" ? (
								<button
									type="button"
									data-open-contact-panel
									class="nav-command touch-target inline-flex items-center rounded px-3 py-2 font-source tracking-wide transition-colors"
									title={`Open ${link.name}`}
								>
									<span>{link.name}</span>
								</button>
							) : link.external ? (
								<a
									href={link.path}
									target="_blank"
									rel="noopener noreferrer"
									class="nav-command touch-target inline-flex items-center rounded px-3 py-2 font-source tracking-wide transition-colors"
									title={`Open ${link.name}`}
								>
									<span>{link.name}</span>
								</a>
							) : (
								<a
									href={link.path}
									class="nav-command touch-target inline-flex items-center rounded px-3 py-2 font-source tracking-wide transition-colors"
									title={`Go to ${link.name}`}
								>
									<span>{link.name}</span>
								</a>
							)}
						</span>
					))
				}
			</div>
		</div>

		{/* Mobile date/time */}
		{
			NAVIGATION.systemInfo.showDateTime && (
				<div
					class="lg:hidden text-xs text-left md:text-center"
					style={{ color: "var(--theme-muted)" }}
				>
					{dateString} {timeString}
				</div>
			)
		}
	</div>
</nav>

<ContactPanel />

<style>
	.theme-toggle {
		width: 2.4rem;
		height: 2.4rem;
		min-height: 2.4rem;
		padding: 0;
		display: inline-grid;
		place-items: center;
		flex: 0 0 auto;
		aspect-ratio: 1;
		border: 1px solid color-mix(in srgb, var(--theme-accent) 75%, #000 25%);
		box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.08) inset;
	}

	.theme-toggle__icon {
		width: 1rem;
		height: 1rem;
	}

	.nav-command {
		color: var(--theme-primary);
		border: 1px solid transparent;
	}

	.nav-command:hover {
		color: var(--theme-background);
		background-color: var(--theme-primary);
		border-color: var(--theme-primary);
	}
</style>

<script>
	import { getThemeDisplayNames } from "../utils/theme";

	const themeDisplayNames = getThemeDisplayNames();
	const themes = Object.keys(themeDisplayNames);
	const themeStorageKey = "site-theme";
	const themeToggle = document.getElementById("themeToggle");

	function getCurrentTheme() {
		const activeTheme = document.documentElement.getAttribute("data-theme");
		if (activeTheme && themes.includes(activeTheme)) {
			return activeTheme;
		}

		try {
			const savedTheme = localStorage.getItem(themeStorageKey);
			if (savedTheme && themes.includes(savedTheme)) {
				return savedTheme;
			}
		} catch {
			return themes[0];
		}

		return themes[0];
	}

	function applyTheme(themeName) {
		document.documentElement.setAttribute("data-theme", themeName);
		if (themeToggle) {
			themeToggle.setAttribute("title", `Theme: ${themeDisplayNames[themeName]}`);
			themeToggle.setAttribute("aria-label", `Theme: ${themeDisplayNames[themeName]}. Tap to switch.`);
		}

		try {
			localStorage.setItem(themeStorageKey, themeName);
		} catch {
			// Ignore storage failures and keep the in-memory theme.
		}
	}

	let current = themes.indexOf(getCurrentTheme());
	if (current < 0) {
		current = 0;
	}

	applyTheme(themes[current]);

	if (themeToggle) {
		themeToggle.addEventListener("click", () => {
			current = (current + 1) % themes.length;
			applyTheme(themes[current]);
		});
	}
</script>
